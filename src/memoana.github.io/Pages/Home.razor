@page "/"

<MudGrid Justify="Justify.Center" Class="mt-6">
    <MudItem xs="12" md="8" Class="text-center">
        <MudText Typo="Typo.h2" Align="Align.Center" Color="Color.Primary" Class="font-weight-bold mb-4">MemoAna</MudText>
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">O jogo de memória definitivo para exercitar sua mente e se divertir.</MudText>
        <MudCard Elevation="4" Class="pa-6 rounded-lg">
            <MudCardContent>
                <MudText Typo="Typo.h4" Class="mb-3">Recursos do Jogo</MudText>
                <MudText Typo="Typo.body1" Align="Align.Left">• Três níveis de dificuldade (Fácil, Médio e Difícil) adaptáveis ao seu ritmo.</MudText>
                <MudText Typo="Typo.body1" Align="Align.Left">• Integração completa com o Google Play Games (Placares de líderes e conquistas).</MudText>
                <MudText Typo="Typo.body1" Align="Align.Left">• Interface fluida e trilha sonora imersiva.</MudText>
            </MudCardContent>
            <MudCardActions Class="justify-center">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" EndIcon="@Icons.Material.Filled.Download" Link="https://play.google.com">Baixar Agora</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>